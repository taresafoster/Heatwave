### 5. Add to original vector

# calculate the total count and mean population using the quadrat method (copy and paste from code review 4)
N = 144

n144 = 144
total <- c()
for(i in 1:1000){
  S <- sample(as.matrix(kangaroo), n144, replace = F)
  total[i] <- (sum(S)*(N)/n144)
}
mean(total)

n8 = 8
out <- c()
for(i in 1:1000){
  S <- sample(as.matrix(kangaroo), n8, replace = F)
  out[i] <- (sum(S)*(N)/n8)
}
mean(out)
sd(out)

n48 = 48
sample(as.matrix(kangaroo), n48, replace = F) 

out2 <- c()
for(i in 1:1000){
  S <- sample(as.matrix(kangaroo), n48, replace = F)
  out2[i] <- (sum(S)*(N)/n48)
}
mean(out2)
sd(out2)

n96 = 96
out3 <- c()
for(i in 1:1000){
  S <- sample(as.matrix(kangaroo), n96, replace = F)
  out3[i] <- (sum(S)*(N)/n96)
}
mean(out3)
sd(out3)

#Create the vector "kangaroosummary" which now includes the transect method to produce 7 samples/rows total
kangaroosummary <- data.frame(
  mean_pop = c(mean(total), mean(out), mean(out2), mean(out3), mean(transect2), mean(transect5), mean(transect8)),
  sd_pop = c(NA, sd(out), sd(out2), sd(out3), sd(transect2), sd(transect5), sd(transect8)),
  method = c("total count", "quadrat 8", "quadrat 48", "quadrat 96", "transect 2", "transect 5", "transect 8")
)

#View ther vector "kangaroosummary"
print(kangaroosummary)

### 6. Figure
# run ggplot2
library(ggplot2)

# create a box plot with error bars denoting standard deviation, x and y axis labels, a figure caption, and a black and white theme.
ggplot(data=kangaroosummary, aes(x = method, y = mean_pop)) +
  geom_boxplot () +
  geom_errorbar(aes(ymin = mean_pop - sd_pop, ymax = mean_pop + sd_pop), width = 0.2) +
  ylab("Mean population size") +
  xlab("Sampling method") +
  labs(caption = "The mean size of a kangaroo population collected by a census and estimated using multiple quadrat and transect methods, 
       as well as a total count of all individuals. Error bars denote standard deviation.") +
  theme(plot.caption = element_text(hjust = 0.5))
  theme_bw() 

