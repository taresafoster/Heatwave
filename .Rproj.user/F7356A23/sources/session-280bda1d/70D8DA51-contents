### 4. Sample the data using 2, 4, and 8 transects. Run each of these samples 1000 times and find the mean and standard deviation for each transect method
transect2 <- c()
for(i in 1:1000){
  S <- sample(kangaroo, t2, replace = F)
  transect2[i] <- (sum(S)*N)/(t*t2)
}

mean(transect2)
sd(transect2)

